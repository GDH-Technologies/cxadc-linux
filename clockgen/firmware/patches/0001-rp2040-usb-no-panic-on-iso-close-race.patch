+// GDHVC local patch (see clockgen/firmware/patches/): per-endpoint DPRAM
+// allocation cache. The stock bump allocator only resets when ALL non-control
+// endpoints are closed, which never happens on a composite device (our CDC
+// endpoints stay open forever) - so every audio SET_INTERFACE open/close
+// cycle leaked one ISO buffer until hard_assert bricked the device. Endpoint
+// geometry is fixed on this device, so a re-opened endpoint simply reuses its
+// previous slot.
+static uint8_t *cached_data_buf[USB_MAX_ENDPOINTS][2];
+static uint cached_data_size[USB_MAX_ENDPOINTS][2];
+
 static void _hw_endpoint_alloc(struct hw_endpoint *ep, uint8_t transfer_type)
 {
   // size must be multiple of 64
@@ -78,12 +89,29 @@ static void _hw_endpoint_alloc(struct hw_endpoint *ep, uint8_t transfer_type)
     size *= 2u;
   }
 
-  ep->hw_data_buf = next_buffer_ptr;
-  next_buffer_ptr += size;
+  uint8_t const cache_num = tu_edpt_number(ep->ep_addr);
+  uint8_t const cache_dir = tu_edpt_dir(ep->ep_addr);
+  if ( cached_data_buf[cache_num][cache_dir] != NULL && cached_data_size[cache_num][cache_dir] >= size )
+  {
+    ep->hw_data_buf = cached_data_buf[cache_num][cache_dir];
+  }
+  else
+  {
+    ep->hw_data_buf = next_buffer_ptr;
+    next_buffer_ptr += size;
+    cached_data_buf[cache_num][cache_dir] = ep->hw_data_buf;
+    cached_data_size[cache_num][cache_dir] = size;
+  }
 
   assert(((uintptr_t )next_buffer_ptr & 0b111111u) == 0);
   uint dpram_offset = hw_data_offset(ep->hw_data_buf);
-  hard_assert(hw_data_offset(next_buffer_ptr) <= USB_DPRAM_MAX);
+  if ( hw_data_offset(next_buffer_ptr) > USB_DPRAM_MAX )
+  {
+    // out of DPRAM: breadcrumb + spin so the watchdog reboots with a diagnosis
+    // instead of the stock hard_assert panic (bricked until power cycle)
+    watchdog_hw->scratch[2] = 0xC1;
+    while (1) { tight_loop_contents(); }
+  }
 
   pico_info("  Allocated %d bytes at offset 0x%x (0x%p)\r\n", size, dpram_offset, ep->hw_data_buf);
 
@@ -116,6 +144,9 @@ static void _hw_endpoint_close(struct hw_endpoint *ep)
     if (reclaim_buffers)
     {
         next_buffer_ptr = &usb_dpram->epx_data[0];
+        // GDHVC local patch: the cached slots point into the reclaimed region
+        memset(cached_data_buf, 0, sizeof(cached_data_buf));
+        memset(cached_data_size, 0, sizeof(cached_data_size));
     }
 }
 
@@ -240,10 +271,17 @@ static void __tusb_irq_path_func(reset_non_control_endpoints)(void)
 
   // reclaim buffer space
   next_buffer_ptr = &usb_dpram->epx_data[0];
+  // GDHVC local patch: the cached slots point into the reclaimed region
+  memset(cached_data_buf, 0, sizeof(cached_data_buf));
+  memset(cached_data_size, 0, sizeof(cached_data_size));
 }
 
 static void __tusb_irq_path_func(dcd_rp2040_irq)(void)
 {
+  // GDHVC local patch: ISR liveness breadcrumbs in watchdog scratch[2]
+  // (0xA0 = in ISR, 0xA1 = ISR exited cleanly; distinct codes at panic sites)
+  watchdog_hw->scratch[2] = 0xA0;
+
   uint32_t const status = usb_hw->ints;
   uint32_t handled = 0;
 
@@ -369,8 +407,12 @@ static void __tusb_irq_path_func(dcd_rp2040_irq)(void)
 
   if ( status ^ handled )
   {
-    panic("Unhandled IRQ 0x%x\n", (uint) (status ^ handled));
+    // GDHVC local patch: mark + spin instead of panic (watchdog reboots with breadcrumb)
+    watchdog_hw->scratch[2] = 0xC0;
+    while (1) { tight_loop_contents(); }
   }
+
+  watchdog_hw->scratch[2] = 0xA1;
 }
 
